{
  "name": "uprevit-ui",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev --filter=@uprevit/app",
    "build": "turbo build --filter=@uprevit/app",
    "start": "bun --cwd apps/app run start",
    "lint": "turbo lint --filter=@uprevit/app",
    "check-types": "turbo check-types --filter=@uprevit/app"
  },
  "devDependencies": {
    "turbo": "^2.8.21"
  }
}
