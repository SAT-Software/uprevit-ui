{
  "name": "uprevit-ui",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "dev:app": "turbo dev --filter=@uprevit/app",
    "dev:marketing": "turbo dev --filter=@uprevit/marketing",
    "build": "turbo build",
    "build:app": "turbo build --filter=@uprevit/app",
    "build:marketing": "turbo build --filter=@uprevit/marketing",
    "start:app": "bun run --cwd apps/app start",
    "start:marketing": "bun run --cwd apps/marketing start",
    "lint": "turbo lint",
    "lint:app": "turbo lint --filter=@uprevit/app",
    "lint:marketing": "turbo lint --filter=@uprevit/marketing",
    "check-types": "turbo check-types",
    "check-types:app": "turbo check-types --filter=@uprevit/app",
    "check-types:marketing": "turbo check-types --filter=@uprevit/marketing"
  },
  "devDependencies": {
    "turbo": "^2.8.21"
  },
  "dependencies": {
    "lottie-react": "^2.4.1"
  }
}
